# Copy this file to .env and fill in the actual values
# .env is in .gitignore and should never be committed

# HashiCorp Vault base URL (default: http://localhost:8200)
VAULT_URI=http://localhost:8200

# Vault authentication token (required; no default)
VAULT_TOKEN=

# KV v2 secret mount path (default: secret)
VAULT_MOUNT_PATH=secret

# Vault read endpoint template (default: /v1/%s/data/%s)
# Placeholders: mount-path, secret-path
VAULT_READ_PATH_TEMPLATE=/v1/%s/data/%s
