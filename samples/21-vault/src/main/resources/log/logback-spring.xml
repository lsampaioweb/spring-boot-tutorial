<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <springProperty scope="context" source="spring.application.name" name="APPLICATION_NAME" />
  <springProperty scope="context" source="app.logging.path" name="LOG_PATH" defaultValue="logs" />

  <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <Pattern>%black(%d{ISO8601}) %highlight(%-5level) [%blue(%t)] %yellow(%logger{60}): %msg%n%throwable</Pattern>
    </encoder>
  </appender>

  <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/${APPLICATION_NAME}.log</file>
    <encoder>
      <Pattern>%d{ISO8601} %-5level [%t] %logger{60}: %msg%n%throwable</Pattern>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/archived/${APPLICATION_NAME}-%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>7</maxHistory>
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <appender name="File" class="ch.qos.logback.classic.AsyncAppender">
    <appender-ref ref="RollingFile" />
  </appender>

  <springProfile name="debug">
    <root level="DEBUG">
      <appender-ref ref="Console" />
      <appender-ref ref="File" />
    </root>
  </springProfile>

  <springProfile name="default | development">
    <root level="DEBUG">
      <appender-ref ref="Console" />
      <appender-ref ref="File" />
    </root>
  </springProfile>

  <springProfile name="production">
    <root level="INFO">
      <appender-ref ref="File" />
    </root>
  </springProfile>

</configuration>